# ================================================================
# NUTRIALC - VARIABILI D'AMBIENTE
# Rinomina questo file in ".env" nella cartella del progetto
# ================================================================

# Supabase (obbligatorio per login/registrazione)
# Trovi questi valori su supabase.com → Il tuo progetto → Settings → API
REACT_APP_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# USDA FoodData Central (facoltativo - lascia DEMO_KEY per uso normale)
# Chiave gratuita su: https://fdc.nal.usda.gov/api-key-signup.html
REACT_APP_USDA_KEY=DEMO_KEY
